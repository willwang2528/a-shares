# 所有真实值只放在本地环境变量或云平台服务端 Secret 中。
# 不要把真实密钥提交到仓库，也不要加 NEXT_PUBLIC_ 前缀。

# 行情源（默认使用零费用的真实指数实验源；正式全市场行情仍需 Token）
MARKET_PROVIDER=tencent_public_experimental
TUSHARE_TOKEN=

# OpenAI-compatible 模型中转（盘中规则不依赖模型）
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=
LLM_TIMEOUT_MS=12000
LLM_MAX_DAILY_COST_USD=0.20

# 通知渠道（二选一即可）
SERVERCHAN_SENDKEY=
RESEND_API_KEY=
NOTIFICATION_EMAIL=
NOTIFICATION_FROM=

# 外部调度器调用 /api/scheduler 时使用
SCHEDULER_SECRET=
